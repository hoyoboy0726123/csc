# 後端環境變數範本
# 複製本檔案為 .env 並填入實際值

# 資料庫
DB_URL=postgresql+asyncpg://user:password@localhost:5432/aicsm

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<key>
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4-1106-preview
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Blob 儲存體
BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<name>;AccountKey=<key>;EndpointSuffix=core.windows.net
BLOB_CONTAINER_NAME=attachments

# ERP API
ERP_API_BASE_URL=https://erp.example.com/api/v1
ERP_API_KEY=<key>

# Email（Outlook）
EMAIL_SMTP_SERVER=smtp.office365.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=noreply@example.com
EMAIL_PASSWORD=<app-password>

# JWT
JWT_SECRET_KEY=<32-random-characters>
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Redis（Rate Limit & Cache）
REDIS_URL=redis://localhost:6379/0

# 環境
ENV=local
LOG_LEVEL=INFO
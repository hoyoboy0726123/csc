# FastAPI 後端環境變數範本
# 請複製本檔案為 .env 並填入實際值

# 應用基本設定
APP_NAME=V2C
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=your-256-bit-secret-key-here-min-32-chars
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# 監聽位址與連接埠
HOST=0.0.0.0
PORT=8000

# 資料庫（SQLite 為預設，零外部依賴）
DATABASE_URL=sqlite+aiosqlite:///./v2c.db

# 檔案上傳限制
UPLOAD_MAX_SIZE_MB=50
UPLOAD_TMP_DIR=./tmp

# JWT 設定
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# 加密金鑰（用於加密儲存用戶的 Gemini / Groq Key）
MASTER_KEY=your-32-bytes-master-key-for-aes-256

# Whisper 服務位址（Docker Compose 內部服務名稱）
WHISPER_URL=http://whisper:9000

# 模型預設值（用戶可於 UI 切換）
DEFAULT_LLM_PROVIDER=gemini
DEFAULT_MODEL_GEMINI=gemini-1.5-pro
DEFAULT_MODEL_GROQ=llama3-70b-8192

# 外部 LLM API Base URL（若使用反向代理或相容 OpenAI 格式）
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GROQ_BASE_URL=https://api.groq.com/openai

# 日誌等級
LOG_LEVEL=INFO

# ZIP 暫存目錄
ZIP_CACHE_DIR=./backend/static/zips
ZIP_CACHE_TTL_HOURS=24

# 配額與速率限制
RATE_LIMIT_PER_MINUTE=60
MAX_PRD_VERSIONS=10
MAX_CODE_VERSIONS=20

# 單元測試用 (pytest)
PYTEST_ASYNCIO_LOOP_SCOPE=function
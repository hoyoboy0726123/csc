OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_ENDPOINT=https://api.openai.com/v1
OPENAI_MODEL=gpt-4
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_AUTHORITY=https://login.microsoftonline.com/${AZURE_TENANT_ID}
AZURE_REDIRECT_URI=http://localhost:8501
AZURE_SCOPES=User.Read,Mail.ReadWrite,Mail.Send
SQLITE_PATH=./data/aicms.db
SQLITE_WAL_MODE=true
LOG_LEVEL=INFO
MAX_PDF_SIZE_MB=10
MAX_EMAIL_CHARS=20000
AI_CONFIDENCE_THRESHOLD=0.8
AI_RETRY_ATTEMPTS=3
AI_RETRY_DELAY_SECONDS=2
OUTLOOK_RETRY_ATTEMPTS=3
OUTLOOK_RETRY_DELAY_SECONDS=5
KPI_CACHE_SECONDS=30
CSV_EXPORT_ENCODING=utf-8
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0